#include <stdio.h>
#include <stdlib.h>
int main() {
    int n, i;
    int *arr1, *arr2;
    printf("Enter number of elements: ");
    scanf("%d", &n);
      arr1 = (int *)malloc(n * sizeof(int));

    if (arr1 == NULL) {
        printf("Memory allocation failed using malloc.\n");
        return 1;
    }
    printf("Enter %d elements for malloc array:\n", n);
    for (i = 0; i < n; i++) {
        scanf("%d", &arr1[i]);
    }
    printf("Elements using malloc:\n");
    for (i = 0; i < n; i++) {
        printf("%d ", arr1[i]);
    }
    arr2 = (int *)calloc(n, sizeof(int));
    if (arr2 == NULL) {
        printf("\nMemory allocation failed using calloc.\n");
        return 1;
    }
    printf("\nElements using calloc (initialized to 0):\n");
    for (i = 0; i < n; i++) {
        printf("%d ", arr2[i]);
    }
     free(arr1);
    free(arr2);

    return 0;
}
