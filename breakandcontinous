#include <stdio.h>

int main() {
    int i;


    printf("Using continue:\n");
    for (i = 1; i <= 10; i++) {
        if (i == 5) {
            continue;  // Skip when i = 5
        }
        printf("%d ", i);
    }

    printf("\n");

    
    printf("Using break:\n");
    for (i = 1; i <= 10; i++) {
        if (i == 5) {
            break;  // Stop loop when i = 5
        }
        printf("%d ", i);
    }

    return 0;
}
