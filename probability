#include <stdio.h>

int fact(int n) {
    if (n == 0 || n == 1)
        return 1;
    else
        return n * fact(n - 1);
}

int nCr(int n, int r) {
    return fact(n) / (fact(r) * fact(n - r));
}

int main() {
    int n, r, result;

    printf("Enter values of n and r (n > r): ");
    scanf("%d %d", &n, &r);

    result = nCr(n, r);

    printf("nCr value = %d", result);

    return 0;
}

