#include <stdio.h>

int main() {
    int arr[5] = {10, 20, 30, 40, 50};
    int *ptr;

    ptr = arr;  // Pointer points to first element of array

    printf("Pointer Arithmetic Demonstration:\n");

    
    for (int i = 0; i < 5; i++) {
        printf("Value = %d, Address = %p\n", *(ptr + i), (ptr + i));
    }

   
    printf("\nAfter incrementing pointer:\n");
    ptr++;
    printf("Now pointer points to value: %d\n", *ptr);

    
    ptr--;
    printf("After decrement, pointer points to value: %d\n", *ptr);

    return 0;
}
