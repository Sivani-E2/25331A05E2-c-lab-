#include <stdio.h>

// Define structure
struct Student {
    int id;
    char name[50];
    float marks;
};

int main() {
    // Declare structure variable
    struct Student s1;

    // Assign values
    s1.id = 101;
    sprintf(s1.name, "Alice");
    s1.marks = 89.5;

    // Access and display members
    printf("Student ID: %d\n", s1.id);
    printf("Student Name: %s\n", s1.name);
    printf("Marks: %.2f\n", s1.marks);

    return 0;
}
