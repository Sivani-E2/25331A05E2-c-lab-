#include <stdio.h>

// Inner structure
struct Date {
    int day;
    int month;
    int year;
};

// Outer structure
struct Student {
    int id;
    char name[50];
    struct Date dob; // Nested structure
};

int main() {
    struct Student s1;

    // Assign values
    s1.id = 102;
    sprintf(s1.name, "Bob");
    s1.dob.day = 15;
    s1.dob.month = 8;
    s1.dob.year = 2005;

    // Display values
    printf("ID: %d\n", s1.id);
    printf("Name: %s\n", s1.name);
    printf("Date of Birth: %d/%d/%d\n",
           s1.dob.day, s1.dob.month, s1.dob.year);

    return 0;
}
