#include <stdio.h>


int isPrime(int num) {
    int i;

    if (num <= 1)
        return 0;

    for (i = 2; i <= num / 2; i++) {
        if (num % i == 0)
            return 0;  
    }

}

int main() {
    int num;

    printf("Enter a number: ");
    scanf("%d", &num);

    if (isPrime(num))
        printf("Prime number");
    else
        printf("Not a prime number");

    return 0;
}
